# Copy to .env and fill in (do not commit .env)
OPENAI_API_KEY=sk-your-key-here

# Default model when the host passes an empty model string
OPENAI_MODEL=gpt-4o-mini

# OpenAI-compatible API root (must expose POST .../chat/completions)
# Examples:
#   https://api.openai.com/v1
#   https://api.openai.com/v1   (default)
#   https://openrouter.ai/api/v1
#   http://127.0.0.1:11434/v1   (Ollama OpenAI compatibility, if enabled)
OPENAI_BASE_URL=https://api.openai.com/v1
