{
  "name": "oclivenewnew",
  "private": true,
  "version": "0.2.0",
  "license": "AGPL-3.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:probe": "node scripts/dev-probe.mjs",
    "verify:ui": "node scripts/verify-frontend-patches.mjs",
    "tauri:dev:verify": "npm run verify:ui && npm run tauri:dev",
    "start:dev": "npm run tauri:dev",
    "push:origin": "git push origin main && git push origin --tags",
    "dev:tauri": "cd src-tauri && npx --no-install tauri dev -c tauri.vite-external.json",
    "tauri:before-dev": "node scripts/tauri-npm.cjs dev",
    "tauri:before-build": "node scripts/tauri-npm.cjs build",
    "build": "vite build",
    "build:analyze": "vite build --mode analyze",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "check:rust:fmt": "cargo fmt --manifest-path src-tauri/Cargo.toml --all -- --check",
    "check:rust:clippy": "cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets --all-features -- -D warnings",
    "check:rust:test": "cargo test --manifest-path src-tauri/Cargo.toml --lib",
    "check:rust:test:all": "cargo test --manifest-path src-tauri/Cargo.toml",
    "check:rust": "npm run check:rust:fmt && npm run check:rust:clippy && npm run check:rust:test",
    "check:license": "node scripts/check-license-readiness.mjs",
    "check": "npm run build && npm run check:rust",
    "check:release": "npm run build && npm run check:rust:fmt && npm run check:rust:clippy && npm run check:rust:test:all",
    "scaffold:ui-plugin": "node scripts/scaffold-ui-slot-plugin.mjs"
  },
  "dependencies": {
    "@sentry/vue": "^10.47.0",
    "@tauri-apps/api": "1.5.6",
    "acorn": "^8.16.0",
    "acorn-walk": "^8.3.5",
    "idb-keyval": "^6.2.2",
    "mitt": "^3.0.1",
    "monaco-editor": "^0.55.1",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "vue": "^3.5.13",
    "vue-virtual-scroller": "^2.0.0",
    "vue3-sfc-loader": "^0.9.5"
  },
  "devDependencies": {
    "@tauri-apps/cli": "1.5.14",
    "@vitejs/plugin-vue": "^5.2.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "vite": "^6.0.3",
    "vite-plugin-monaco-editor": "^1.1.0"
  }
}
