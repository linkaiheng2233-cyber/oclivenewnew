{
  "build": {
    "beforeBuildCommand": "node scripts/tauri-run.cjs build",
    "beforeDevCommand": "node scripts/tauri-run.cjs dev",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../roles"
    ]
  },
  "productName": "oclivenewnew",
  "mainBinaryName": "oclivenewnew",
  "version": "0.2.0",
  "identifier": "com.oclivenewnew.app",
  "plugins": {},
  "app": {
    "windows": [
      {
        "fullscreen": false,
        "height": 600,
        "resizable": true,
        "title": "oclivenewnew",
        "width": 800
      }
    ],
    "security": {
      "assetProtocol": {
        "scope": [
          "**"
        ],
        "enable": true
      },
      "csp": null
    }
  }
}